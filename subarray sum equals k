class Solution:
    def subarraySum(self, nums: List[int], k: int) -> int:
        n=len(nums)
        d={0:1}
        count=0
        sum=0
        for i in range (0,n):
            sum += nums[i]
            if(sum-k in d):
                count+=d[sum-k]
            if (sum in d) :
                d[sum]  +=1
            else:
                d[sum]  =1
        return count           



        
